{
  "private": true,
  "scripts": {
    "postinstall": "biome migrate --write",
    "build": "pnpm run --sequential '/^build:.*/'",
    "build:wasm": "wasm-pack build --release -t bundler",
    "build:web": "vite build",
    "check": "pnpm run '/^check:.*/'",
    "check:wasm": "cargo clippy --all-targets --all-features",
    "check:web": "tsc",
    "start": "vite serve --open",
    "preview": "vite preview --open",
    "lint": "pnpm run '/^lint:.*/'",
    "lint:wasm": "cargo fmt --all --check",
    "lint:web": "biome check --write www",
    "test": "wasm-pack test --headless --chrome",
    "ncu": "mise run ncu"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "terser": "5.48.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vite-plugin-wasm": "3.6.0"
  },
  "packageManager": "pnpm@11.0.8"
}
